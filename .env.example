# ============================================================
# DerivAI Agent — Environment Variables
# ============================================================
# Copy this file to .env.local for local development
# Add these to Vercel → Settings → Environment Variables for production
# ============================================================

# ── Deriv App ID ────────────────────────────────────────────
# Register your own app at: https://api.deriv.com/
# Default (1089) is Deriv's public app_id — works but has rate limits.
# Create your own at https://app.deriv.com/account/api-token
# then register an OAuth app at https://developers.deriv.com/
NEXT_PUBLIC_DERIV_APP_ID=1089

# ── Optional: OAuth (for Login with Deriv button) ──────────
# Only needed if you want OAuth login flow instead of manual token entry.
# Register your app at https://api.deriv.com/#oauth
NEXT_PUBLIC_DERIV_OAUTH_URL=https://oauth.deriv.com/oauth2/authorize

# ── App URL (Required for Vercel deployment) ───────────────
# Your deployed Vercel URL — used for OAuth redirect
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
